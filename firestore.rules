rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (getUserData().rol == 'admin' ||
          (request.auth.token.email == "martinivanarteaga@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function belongsToCompany(companyId) {
      return isAuthenticated() && (getUserData().empresa_id == companyId || isAdmin());
    }
    
    function isCompanyMember(data) {
      return isAuthenticated() && (getUserData().empresa_id == data.empresa_id || isAdmin());
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /empresas/{empresaId} {
      allow create: if isAuthenticated();
      allow read, update: if belongsToCompany(empresaId);
    }

    match /usuarios/{usuarioId} {
      allow create: if isOwner(usuarioId);
      allow read, update: if isAuthenticated() && (isOwner(usuarioId) || belongsToCompany(resource.data.empresa_id));
    }

    match /productos/{id} {
      allow create: if isAuthenticated() && isCompanyMember(request.resource.data);
      allow read, update, delete: if isAuthenticated() && isCompanyMember(resource.data);
    }

    match /clientes/{id} {
      allow create: if isAuthenticated() && isCompanyMember(request.resource.data);
      allow read, update, delete: if isAuthenticated() && isCompanyMember(resource.data);
    }

    match /proveedores/{id} {
      allow create: if isAuthenticated() && isCompanyMember(request.resource.data);
      allow read, update, delete: if isAuthenticated() && isCompanyMember(resource.data);
    }

    match /ventas/{id} {
      allow create: if isAuthenticated() && isCompanyMember(request.resource.data);
      allow read, update, delete: if isAuthenticated() && isCompanyMember(resource.data);
    }

    match /detalles_venta/{id} {
      allow read, write: if isAuthenticated();
    }

    match /compras/{id} {
      allow create: if isAuthenticated() && isCompanyMember(request.resource.data);
      allow read, update, delete: if isAuthenticated() && isCompanyMember(resource.data);
    }

    match /detalles_compra/{id} {
      allow read, write: if isAuthenticated();
    }

    match /cajas/{id} {
      allow create: if isAuthenticated() && isCompanyMember(request.resource.data);
      allow read, update, delete: if isAuthenticated() && isCompanyMember(resource.data);
    }

    match /movimientos_caja/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}
